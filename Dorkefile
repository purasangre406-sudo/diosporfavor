FROM nginx:alpine

# Copia todos tus archivos al servidor
COPY . /usr/share/nginx/html/

# LE DICE AL SERVIDOR QUE BUSQUE TU ARCHIVO PERSONALIZADO EN LUGAR DE INDEX.HTML
# (Cambia "inicio.html" por el nombre real que le hayas puesto a tu archivo)
RUN sed -i 's/index.html/inicio.html/g' /etc/nginx/conf.d/default.conf

EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
