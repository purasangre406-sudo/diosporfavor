# Usa el entorno oficial de Python
FROM python:3.10-slim

# Crea la carpeta de trabajo
WORKDIR /app

# Copia tus archivos de requisitos e instálalos si existen
COPY requirements.txt* ./
RUN pip install --no-cache-dir -r requirements.txt || true

# Copia todo tu código
COPY . .

# El comando que arranca tu script principal
CMD ["python", "app.py"]
